{
  "name": "@bounded-systems/machine-schema",
  "version": "0.3.0",
  "description": "Brands, handoff envelope, and state/phase/invariant primitives for work-unit machines",
  "bounded": {
    "tagline": "Brands, handoff envelope, and state/phase/invariant primitives for work-unit machines",
    "kind": "room",
    "facet": "noun",
    "role": "schema",
    "domain": "state-machine/types"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/machine-schema.git"
  },
  "homepage": "https://github.com/bounded-systems/machine-schema#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/machine-schema/issues"
  },
  "keywords": [
    "schema",
    "brands",
    "state-machine",
    "work-unit",
    "zod"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@bounded-systems/seam-check": "npm:@jsr/bounded-systems__seam-check@^0.1.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
